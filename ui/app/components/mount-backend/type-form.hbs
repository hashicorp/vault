            data-test-mount-type={{type.type}}
          >
            <Icon @name={{type.glyph}} @size="24" class="has-bottom-margin-xs" />
            <Hds::Text::Body @tag="h3" @size="300">
              {{type.displayName}}
            </Hds::Text::Body>
            {{#if (or type.version type.builtin)}}
              <PluginStatusIndicator
                @version={{type.version}}
