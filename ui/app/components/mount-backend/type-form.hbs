            {{#if type.demoDisabled}}
              <Hds::Badge @text="Demo" @color="warning" @size="small" class="has-top-margin-xs" />
            {{/if}}
          </Hds::Card::Container>
        {{/each}}
      {{/let}}
    {{else if (eq category "infra")}}
      {{#let this.infraMountTypes as |categorized|}}
        {{! Display enabled plugins first }}
        {{#each categorized.enabled as |type|}}
          <Hds::Card::Container
            tabindex={{unless (if type.requiredFeature (not (has-feature type.requiredFeature)) false) "0"}}
