<Hds::Card::Container
  class="selectable-engine-card has-top-padding-l has-bottom-padding-s has-text-centered small-card"
  @level="base"
  @background="neutral-secondary"
  @hasBorder={{false}}
  {{on "click" (fn @handleDisabledPluginClick @type)}}
  {{on "keypress" (fn @handleDisabledPluginClick @type)}}
  data-test-mount-type={{@type.type}}
  data-test-disabled-plugin
>
  {{#if @type.glyph}}
    <Icon @name={{@type.glyph}} @size="24" class="has-bottom-margin-xs disabled-icon" />
  {{/if}}
  <Hds::Text::Body @tag="h3" @size="300">
    {{@type.displayName}}
  </Hds::Text::Body>
</Hds::Card::Container>