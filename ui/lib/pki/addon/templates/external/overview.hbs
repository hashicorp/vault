{{#let (and this.model.canListAcmeConfig (not this.model.acmeAccounts.length)) as |isNotConfigured|}}
  <ExternalPki::HeaderTabs
    @backend={{this.model.engine}}
    @isNotConfigured={{isNotConfigured}}
    @breadcrumbs={{this.breadcrumbs}}
  />

  <ExternalPki::Page::Overview @model={{this.model}} @isNotConfigured={{isNotConfigured}} />
{{/let}}