<ExternalPki::HeaderTabs @title={{this.model.role_name}} @breadcrumbs={{this.breadcrumbs}}>
  <:tabs>
    <li>
      <LinkTo
        @current-when={{matches-current-url "external.roles.role.details"}}
        @route="external.roles.role.details"
        @models={{array this.model.engine.id this.model.role_name}}
        data-test-link-to="Details"
      >Details</LinkTo>
    </li>
    <li>
      <LinkTo
        @current-when={{matches-current-url "external.roles.role.active-orders"}}
        @route="external.roles.role.active-orders"
        @models={{array this.model.engine.id this.model.role_name}}
        data-test-link-to="Active orders"
      >Active Orders</LinkTo>
    </li>
  </:tabs>
</ExternalPki::HeaderTabs>

{{outlet}}