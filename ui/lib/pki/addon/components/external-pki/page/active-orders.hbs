{{#if @model.activeOrders.length}}
  <Hds::Layout::Flex class="has-top-margin-s bottom-margin-8">
    <Hds::Form::TextInput::Field
      @width="300px"
      @type="search"
      placeholder="Filter by order ID"
      aria-label="Filter by order I D"
      data-test-input-search="Filter by order ID"
      {{on "input" this.handleSearch}}
    />

    <Hds::Button
      class="margin-left-auto"
      @color="tertiary"
      @icon="reload"
      @iconPosition="trailing"
      @text="Refresh"
      {{on "click" this.refresh}}
      data-test-button="Refresh"
    />
  </Hds::Layout::Flex>

  {{#if this.filteredOrders}}
    <ListTable @columns={{this.tableColumns}} @data={{this.filteredOrders}}>
      <:customTableItem as |order|>
        <Hds::Link::Inline
          @route="external.orders.order"
          @models={{array @model.engine.id order.order_id}}
          @color="secondary"
          class="has-text-weight-semibold"
          data-test-link-to={{order.order_id}}
        >{{order.order_id}}</Hds::Link::Inline>
      </:customTableItem>
    </ListTable>
  {{else}}
    <Hds::ApplicationState class="top-padding-32 is-marginless" as |A|>
      <A.Header @title="No orders matching ID: {{this.orderFilter}}" @titleTag="h2" data-test-empty-state-title />
    </Hds::ApplicationState>
  {{/if}}
{{else}}
  <Hds::ApplicationState class="top-padding-32" as |A|>
    <A.Header @title="No active orders" @titleTag="h2" data-test-empty-state-title />
    <A.Body data-test-empty-state-message>
      In progress orders will appear here once created. Lookup a specific order by its ID or navigate to
      <Hds::Link::Inline @route="external.orders">Recent orders</Hds::Link::Inline>
      to view recently created and completed orders.
      <Hds::Layout::Flex @gap="8" class="has-top-padding-m" as |LF|>
        <LF.Item @grow={{1}}>
          <InputSearch
            @placeholder="01936d8e-7c3..."
            @onChange={{fn (mut this.orderIdLookup)}}
            @changeEvent="input"
            @id="orderId"
          />
        </LF.Item>
        <LF.Item>
          <Hds::Button
            @text="Lookup order"
            @color="secondary"
            {{on "click" this.lookupOrder}}
            data-test-button="Lookup order"
          />
        </LF.Item>
      </Hds::Layout::Flex>
    </A.Body>
    <A.Footer as |F|>
      <F.LinkStandalone
        @icon="docs-link"
        @text="API docs: Create a new order"
        @href={{doc-link "/vault/api-docs/secret/pki-external-ca#create-new-order"}}
        @iconPosition="trailing"
        data-test-link-to="API docs: Create a new order"
      />
    </A.Footer>
  </Hds::ApplicationState>
{{/if}}