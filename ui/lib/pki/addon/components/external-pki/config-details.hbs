{{#each-in @config as |configParam configValue|}}
  {{#unless (includes configParam this.excludedFields)}}
    {{#if (eq configParam "trusted_ca")}}
      <InfoTableRow @label={{this.label configParam}}>
        <EncodedDataCard @data={{configValue}} />
      </InfoTableRow>
    {{else}}
      <InfoTableRow @label={{this.label configParam}} @value={{configValue}} @formatTtl={{eq configParam "ttl"}} />
    {{/if}}
  {{/unless}}
{{/each-in}}