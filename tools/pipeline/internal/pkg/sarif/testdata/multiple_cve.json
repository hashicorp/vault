{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "TestScanner",
          "version": "1.0.0",
          "rules": [
            {
              "id": "CVE-2024-1234",
              "name": "CVE-2024-1234",
              "shortDescription": {
                "text": "Critical vulnerability in component X"
              },
              "relationships": [
                {
                  "target": {
                    "id": "CVE-2024-1234",
                    "toolComponent": {
                      "name": "CVE"
                    }
                  }
                }
              ]
            },
            {
              "id": "CVE-2024-5678",
              "name": "CVE-2024-5678",
              "shortDescription": {
                "text": "High severity vulnerability in component Y"
              },
              "relationships": [
                {
                  "target": {
                    "id": "CVE-2024-5678",
                    "toolComponent": {
                      "name": "CVE"
                    }
                  }
                }
              ]
            },
            {
              "id": "CVE-2024-9999",
              "name": "CVE-2024-9999",
              "shortDescription": {
                "text": "Medium severity vulnerability in component Z"
              },
              "relationships": [
                {
                  "target": {
                    "id": "CVE-2024-9999",
                    "toolComponent": {
                      "name": "CVE"
                    }
                  }
                }
              ]
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "CVE-2024-1234",
          "message": {
            "text": "Critical vulnerability detected"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/main.go"
                }
              }
            }
          ]
        },
        {
          "ruleId": "CVE-2024-5678",
          "message": {
            "text": "High severity vulnerability detected"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/utils.go"
                }
              }
            }
          ]
        },
        {
          "ruleId": "CVE-2024-9999",
          "message": {
            "text": "Medium severity vulnerability detected"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/config.go"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
